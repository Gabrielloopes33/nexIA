generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Organization - Tenant principal do sistema
/// Cada organização pode ter múltiplos usuários com diferentes roles
model Organization {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String               @unique
  ownerId        String?              @map("owner_id") @db.Uuid
  status         String?              @default("ACTIVE")
  settings       Json?                @default("{}")
  setupComplete  Boolean              @default(false) @map("setup_complete")
  segment        String?              @db.VarChar(50)
  logoUrl        String?              @map("logo_url")
  createdAt      DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  members        OrganizationMember[]
  owner          User?                @relation("OwnedOrganizations", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pipelineStages PipelineStage[]

  @@map("organizations")
}

/// OrganizationMember - Relacionamento many-to-many entre User e Organization
/// Um usuário pode ter roles diferentes em organizações diferentes
model OrganizationMember {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  role           String        @default("MEMBER")
  status         String?       @default("ACTIVE")
  joinedAt       DateTime?     @default(now()) @map("joined_at") @db.Timestamptz(6)
  createdAt      DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

/// User - Usuário do sistema
model User {
  id                 String               @id @default(uuid()) @db.Uuid
  email              String               @unique
  name               String?
  avatarUrl          String?              @map("avatar_url")
  phone              String?
  status             String?              @default("ACTIVE")
  createdAt          DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// Legado: campo usado na migração do Supabase Cloud. Preferir usar memberships.
  organizationId     String?              @map("organization_id") @db.Uuid
  memberships        OrganizationMember[]
  ownedOrganizations Organization[]       @relation("OwnedOrganizations")

  @@map("users")
}

/// UserCredential - Credenciais de autenticação do usuário
model UserCredential {
  userId       String   @id @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user_credentials")
}

/// WhatsAppInstance - Instância WhatsApp Business
/// Modelo adaptado para tabela whatsapp_cloud_instances do Aurea
model WhatsAppInstance {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  name                String    @db.VarChar(255)
  phoneNumber         String    @map("phone_number") @db.VarChar(50)
  phoneNumberId       String?   @map("phone_number_id") @db.VarChar(100)
  wabaId              String?   @map("waba_id") @db.VarChar(100)
  accessToken         String?   @map("access_token")
  displayPhoneNumber  String?   @map("display_phone_number") @db.VarChar(50)
  verifiedName        String?   @map("verified_name") @db.VarChar(255)
  status              String    @default("DISCONNECTED") @map("status") @db.VarChar(50)
  qualityRating       String    @default("UNKNOWN") @map("quality_rating") @db.VarChar(20)
  messagingLimit      Int?      @map("messaging_limit")
  messagingTier       Int?      @map("messaging_tier")
  connectedAt         DateTime? @map("connected_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("whatsapp_cloud_instances")
}

/// EvolutionInstance - Instância WhatsApp via Evolution API (não oficial)
/// Armazena instâncias conectadas via Evolution API para WhatsApp não oficial
model EvolutionInstance {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  name              String   @db.VarChar(255)
  instanceName      String   @unique @map("instance_name") @db.VarChar(255)

  // Connection Info
  status            String   @default("DISCONNECTED") @map("status") @db.VarChar(50)
  phoneNumber       String?  @map("phone_number") @db.VarChar(50)
  profilePictureUrl String?  @map("profile_picture_url")
  profileName       String?  @map("profile_name") @db.VarChar(255)

  // Evolution API Config
  apiKey            String?  @map("api_key") @db.VarChar(255)

  // Webhook Config
  webhookEnabled    Boolean  @default(true) @map("webhook_enabled")
  webhookUrl        String?  @map("webhook_url")

  // Statistics
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")

  // Timestamps
  connectedAt       DateTime? @map("connected_at")
  disconnectedAt    DateTime? @map("disconnected_at")
  lastActivityAt    DateTime? @map("last_activity_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([status])
  @@map("evolution_instances")
}

/// Contact - Contatos unificados (WhatsApp, Instagram, etc)
model Contact {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String        @map("organization_id") @db.Uuid
  phone             String        @db.VarChar(50)
  name              String?       @db.VarChar(255)
  avatarUrl         String?       @map("avatar_url")
  metadata          Json?
  tags              String[]
  leadScore         Int           @default(0) @map("lead_score")
  status            ContactStatus @default(ACTIVE)
  lastInteractionAt DateTime?     @map("last_interaction_at")
  deletedAt         DateTime?     @map("deleted_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")
  contactTags       ContactTag[]
  listContacts      ListContact[]
  deals             Deal[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([status])
  @@map("contacts")
}

/// Conversation - Conversas (janela de 24h)
model Conversation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  contactId      String    @map("contact_id") @db.Uuid
  status         String    @default("active") @db.VarChar(50)
  unread_count   Int       @default(0)
  typingUntil    DateTime? @map("typing_until")  // quando o contato para de "estar digitando"
  typingPhone    String?   @map("typing_phone") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("conversations")
}

/// Message - Mensagens
model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  contactId      String   @map("contact_id") @db.Uuid
  content        String?
  status         String   @default("sent") @db.VarChar(50)
  messageId      String?  @map("message_id") @db.VarChar(255) // ID externo da mensagem (Evolution/Meta)
  direction      String   @default("OUTBOUND") @db.VarChar(20) // INBOUND ou OUTBOUND
  createdAt      DateTime @default(now()) @map("created_at")
  updated_at     DateTime @default(now())

  @@map("messages")
}

/// PipelineStage - Etapas do funil de vendas
model PipelineStage {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  name           String
  position       Int
  color          String?
  probability    Int?          @default(0)
  isDefault      Boolean?      @default(false) @map("is_default")
  isClosed       Boolean?      @default(false) @map("is_closed")
  createdAt      DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  deals          Deal[]

  @@map("pipeline_stages")
}

/// Deal - Oportunidades no pipeline
model Deal {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String                 @map("organization_id") @db.Uuid
  contactId         String                 @map("contact_id") @db.Uuid
  stageId           String                 @map("stage_id") @db.Uuid
  title             String                 @db.VarChar(255)
  description       String?
  value             Decimal                @default(0) @db.Decimal(12, 2)
  probability       Int                    @default(0)
  expectedCloseDate DateTime?              @map("expected_close_date")
  actualCloseDate   DateTime?              @map("actual_close_date")
  status            DealStatus
  lostReason        String?                @map("lost_reason")
  metadata          Json?
  assignedTo        String?                @map("assigned_to") @db.Uuid
  createdBy         String                 @map("created_by") @db.Uuid
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @default(now()) @map("updated_at")
  unitId            String?                @map("unit_id") @db.Uuid
  amount            Decimal?               @db.Decimal(15, 2)
  channel           ChannelType?           @default(OTHER)
  estimatedValue    Float?                 @default(0) @map("estimated_value")
  qualifiedAt       DateTime?              @map("qualified_at") @db.Timestamp(6)
  proposalSentAt    DateTime?              @map("proposal_sent_at") @db.Timestamp(6)
  negotiationAt     DateTime?              @map("negotiation_at") @db.Timestamp(6)
  utmSource         String?                @map("utm_source") @db.VarChar(255)
  currency          String?                @default("BRL") @db.VarChar(3)
  closedWonAt       DateTime?              @map("closed_won_at") @db.Timestamp(6)
  leadScore         Int?                   @default(0) @map("lead_score")
  lostAt            DateTime?              @map("lost_at") @db.Timestamp(6)
  priority          String?                @default("MEDIUM") @db.VarChar(20)
  source            String?                @db.VarChar(100)
  sourceId          String?                @map("source_id") @db.VarChar(100)
  tags              String[]               @default([])
  closedLostAt      DateTime?              @map("closed_lost_at") @db.Timestamp(6)
  stageHistory      PipelineStageHistory[]
  contact           Contact                @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stage             PipelineStage          @relation(fields: [stageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId])
  @@index([status])
  @@index([leadScore])
  @@index([channel, createdAt])
  @@index([qualifiedAt])
  @@index([proposalSentAt])
  @@index([lostReason, closedLostAt])
  @@map("deals")
}

model PipelineStageHistory {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId    String    @map("deal_id") @db.Uuid
  stage     String    @db.VarChar(255)
  enteredAt DateTime? @default(now()) @map("entered_at") @db.Timestamp(6)
  exitedAt  DateTime? @map("exited_at") @db.Timestamp(6)
  duration  Int?
  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([dealId])
  @@index([stage, enteredAt])
  @@index([exitedAt])
  @@map("pipeline_stage_history")
}

model MonthlyGoal {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  month          Int
  year           Int
  revenueGoal    Decimal  @default(0) @map("revenue_goal") @db.Decimal(12, 2)
  dealsGoal      Int      @default(0) @map("deals_goal")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")
  target_revenue Decimal? @default(0) @db.Decimal(15, 2)
  target_deals   Int?     @default(0)
  leadsGoal      Int?     @default(0) @map("leads_goal")
  conversionGoal Decimal? @default(0) @map("conversion_goal") @db.Decimal(5, 2)
  active         Boolean? @default(true)

  @@unique([organizationId, month], map: "idx_monthly_goals_org_month")
  @@unique([organizationId, year, month], map: "monthly_goals_org_year_month_key")
  @@unique([organizationId, month, year])
  @@index([month])
  @@index([year])
  @@index([organizationId], map: "monthly_goals_org_idx")
  @@map("monthly_goals")
}

model DashboardMetricCache {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  metricType     String   @map("metric_type")
  period         String
  data           Json
  calculatedAt   DateTime @default(now()) @map("calculated_at")
  expiresAt      DateTime @map("expires_at")

  @@unique([organizationId, metricType, period], map: "dashboard_metric_cache_org_type_period_key")
  @@index([expiresAt])
  @@index([organizationId, metricType], map: "dashboard_metric_cache_org_type_idx")
  @@map("dashboard_metric_cache")
}

/// DealActivity - Atividades e timeline do deal
model DealActivity {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId      String       @map("deal_id") @db.Uuid
  user_id     String       @db.Uuid
  type        ActivityType
  description String?
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([dealId])
  @@map("deal_activities")
}

model Schedule {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  type           ScheduleType
  title          String
  description    String?
  contactId      String?        @map("contact_id") @db.Uuid
  dealId         String?        @map("deal_id") @db.Uuid
  assignedTo     String?        @map("assigned_to") @db.Uuid
  startTime      DateTime       @map("start_time")
  endTime        DateTime       @map("end_time")
  completedAt    DateTime?      @map("completed_at")
  status         ScheduleStatus @default(pending)
  location       String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("schedules")
}

/// Transcription - Transcrições de chamadas e áudios analisados pela IA
model Transcription {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String              @map("organization_id") @db.Uuid
  contactId        String?             @map("contact_id") @db.Uuid
  scheduleId       String?             @map("schedule_id") @db.Uuid
  conversationId   String?             @map("conversation_id") @db.Uuid
  source           TranscriptionSource
  sourceId         String?             @map("source_id")
  title            String?
  duration         Int?                // segundos
  status           TranscriptionStatus @default(PENDING)
  transcript       String?
  summary          String?
  sentiment        String?
  sentimentScore   Float?              @map("sentiment_score")
  objections       Json?
  keyTopics        String[]            @default([]) @map("key_topics")
  actionItems      String[]            @default([]) @map("action_items")
  converted        Boolean?            @default(false)
  resolutionDays   Int?                @map("resolution_days")
  audioUrl         String?             @map("audio_url")
  audioSize        Int?                @map("audio_size")
  audioFormat      String?             @map("audio_format")
  recordedAt       DateTime?           @map("recorded_at")
  processedAt      DateTime?           @map("processed_at")
  language         String?             @default("pt-BR")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([scheduleId])
  @@index([status])
  @@index([source])
  @@map("transcriptions")
}

/// SchedulingQueue - Fila de leads aguardando agendamento
model SchedulingQueue {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  contactId      String              @map("contact_id") @db.Uuid
  tagId          String?             @map("tag_id") @db.Uuid
  source         String              @default("manual") // webhook, manual, chatbot
  priority       Int                 @default(0) // 0-10, maior = mais prioritário
  status         QueueStatus         @default(WAITING)
  notes          String?
  assignedTo     String?             @map("assigned_to") @db.Uuid
  scheduledAt    DateTime?           @map("scheduled_at")
  completedAt    DateTime?           @map("completed_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([contactId])
  @@map("scheduling_queue")
}

/// Tag - Tags para categorização de contatos
model Tag {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(100)
  color          String       @default("#6366f1") @db.VarChar(20)
  description    String?
  source         String       @default("manual") @db.VarChar(50)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at")
  contactTags    ContactTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

/// ContactTag - Relacionamento many-to-many entre Contact e Tag
model ContactTag {
  contactId  String   @map("contact_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by") @db.Uuid
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

/// List - Listas de contatos (estáticas ou dinâmicas)
model List {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String        @db.VarChar(200)
  description    String?
  color          String        @default("#46347F") @db.VarChar(7)
  filters        Json          @default("{}")
  isDynamic      Boolean       @default(false) @map("is_dynamic")
  contactCount   Int           @default(0) @map("contact_count")
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  listContacts   ListContact[]

  @@map("lists")
}

/// ListContact - Relacionamento many-to-many entre List e Contact
model ListContact {
  listId    String   @map("list_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at")
  addedBy   String?  @map("added_by") @db.Uuid
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@map("list_contacts")
}

/// Segment - Segmentos dinâmicos de contatos
model Segment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  name             String    @db.VarChar(200)
  description      String?
  color            String    @default("#46347F") @db.VarChar(20)
  operator         String    @default("AND") @db.VarChar(10)
  rules            Json      @default("[]")
  contactCount     Int       @default(0) @map("contact_count")
  lastCalculatedAt DateTime? @map("last_calculated_at")
  createdBy        String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("segments")
}

/// Plan - Planos de assinatura
model Plan {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String         @db.VarChar(255)
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  interval      String         @default("month") @db.VarChar(50)
  features      Json?
  is_active     Boolean        @default(true)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
  
  // Relações
  subscriptions Subscription[]

  @@map("plans")
}

/// Subscription - Assinaturas
model Subscription {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  trial_ends_at      DateTime?
  cancelled_at       DateTime?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")
  
  // Relações
  plan               Plan               @relation(fields: [planId], references: [id])
  invoices           Invoice[]

  @@map("subscriptions")
}

/// Invoice - Faturas
model Invoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  subscriptionId String?   @map("subscription_id") @db.Uuid
  amount         Decimal   @db.Decimal(10, 2)
  currency       String    @default("BRL") @db.VarChar(3)
  status         String    @default("PENDING") @db.VarChar(50)
  dueDate        DateTime  @map("due_date")
  paidAt         DateTime? @map("paid_at")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relações
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  charges        Charge[]

  @@map("invoices")
}

/// Charge - Cobranças
model Charge {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  invoiceId      String?      @map("invoice_id") @db.Uuid
  amount         Decimal      @db.Decimal(10, 2)
  status         ChargeStatus @default(PENDING)
  type           ChargeType   @default(RECURRING)
  description    String?
  due_date       DateTime
  paidAt         DateTime?    @map("paid_at")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at")
  
  // Relações
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])

  @@map("charges")
}

model dashboard_metric_caches {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  metric_type     String    @db.VarChar(100)
  period          String    @db.VarChar(50)
  data            Json
  calculated_at   DateTime  @default(now())
  expires_at      DateTime?
}

model pipeline_stage_histories {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id       String   @db.Uuid
  from_stage_id String?  @db.Uuid
  to_stage_id   String   @db.Uuid
  moved_by      String   @db.Uuid
  moved_at      DateTime @default(now())
  created_at    DateTime @default(now())

  @@index([deal_id])
}

/// Campaign - Disparo em massa de mensagens WhatsApp
model Campaign {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  name             String           @db.VarChar(255)
  status           CampaignStatus   @default(DRAFT)
  instanceId       String           @map("instance_id") @db.Uuid
  templateName     String           @map("template_name") @db.VarChar(255)
  templateLanguage String           @map("template_language") @db.VarChar(20)
  templateComponents Json?          @map("template_components")
  audienceType     AudienceType     @default(MANUAL) @map("audience_type")
  audienceTags     String[]         @default([]) @map("audience_tags")
  totalContacts    Int              @default(0) @map("total_contacts")
  sentCount        Int              @default(0) @map("sent_count")
  failedCount      Int              @default(0) @map("failed_count")
  pendingCount     Int              @default(0) @map("pending_count")
  startedAt        DateTime?        @map("started_at")
  completedAt      DateTime?        @map("completed_at")
  createdBy        String           @map("created_by") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at")
  contacts         CampaignContact[]

  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

/// CampaignContact - Contato individual de uma campanha
model CampaignContact {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId        String                @map("campaign_id") @db.Uuid
  contactId         String                @map("contact_id") @db.Uuid
  phone             String                @db.VarChar(50)
  name              String?               @db.VarChar(255)
  status            CampaignContactStatus @default(PENDING)
  externalMessageId String?               @map("external_message_id") @db.VarChar(255)
  errorMessage      String?               @map("error_message") @db.Text
  sentAt            DateTime?             @map("sent_at")
  failedAt          DateTime?             @map("failed_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  campaign          Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@map("campaign_contacts")
}

