/// LinkedInIntegration - Conexão OAuth com LinkedIn Ads por organização
model LinkedInIntegration {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String    @unique @map("organization_id") @db.Uuid

  /// Dados da conta LinkedIn conectada
  linkedInMemberId      String?   @map("linkedin_member_id") @db.VarChar(100)
  linkedInMemberName    String?   @map("linkedin_member_name") @db.VarChar(255)
  linkedInMemberEmail   String?   @map("linkedin_member_email") @db.VarChar(255)

  /// Tokens OAuth (armazenados encriptados)
  accessToken           String    @map("access_token")
  refreshToken          String?   @map("refresh_token")
  expiresAt             DateTime? @map("expires_at")

  /// Configuração escolhida pelo admin
  adAccountId           String?   @map("ad_account_id") @db.VarChar(100)
  adAccountName         String?   @map("ad_account_name") @db.VarChar(255)
  selectedFormIds       String[]  @default([]) @map("selected_form_ids")
  pipelineId            String?   @map("pipeline_id") @db.Uuid
  productId             String?   @map("product_id") @db.Uuid

  /// Webhook
  webhookSubscriptionId String?   @map("webhook_subscription_id") @db.VarChar(255)

  /// Status: PENDING | CONFIGURED | ACTIVE | ERROR | DISCONNECTED
  status                String    @default("PENDING") @db.VarChar(50)

  lastLeadAt            DateTime? @map("last_lead_at")
  totalLeads            Int       @default(0) @map("total_leads")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("linkedin_integrations")
}

