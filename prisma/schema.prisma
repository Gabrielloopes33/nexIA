generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Organization - Tenant principal do sistema
/// Cada organização pode ter múltiplos usuários com diferentes roles
model Organization {
  id                     String                   @id @default(uuid())
  name                   String
  slug                   String                   @unique
  ownerId                String                   @map("owner_id")
  logoUrl                String?                  @map("logo_url")
  featureFlags           Json?                    @map("feature_flags")
  settings               Json?
  status                 OrganizationStatus       @default(ACTIVE)
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  aiInsights             AiInsight[]
  charges                Charge[]
  contacts               Contact[]
  conversations          Conversation[]
  customFieldDefinitions CustomFieldDefinition[]
  deals                  Deal[]
  instagramInstances     InstagramInstance[]
  integrationLogs        IntegrationActivityLog[]
  integrations           Integration[]
  invoices               Invoice[]
  lists                  List[]
  metaWebhookLogs        MetaWebhookLog[]
  members                OrganizationMember[]
  units                  OrganizationUnit[]
  owner                  User                     @relation("OwnedOrganizations", fields: [ownerId], references: [id])
  legacyUsers            User[]                   @relation("LegacyUserOrganization")
  pendingFormDeliveries  PendingFormDelivery[]
  pipelineStages         PipelineStage[]
  schedules              Schedule[]
  segments               Segment[]
  subscriptions          Subscription[]
  tags                   Tag[]
  transcriptions         Transcription[]
  whatsappInstances      WhatsAppInstance[]

  @@index([ownerId])
  @@index([status])
  @@index([slug])
  @@map("organizations")
}

/// OrganizationMember - Relacionamento many-to-many entre User e Organization
/// Um usuário pode ter roles diferentes em organizações diferentes
model OrganizationMember {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  role           OrganizationRole @default(MEMBER)
  status         MemberStatus     @default(ACTIVE)
  joinedAt       DateTime         @default(now()) @map("joined_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@map("organization_members")
}

/// OrganizationUnit - Unidades/Filiais de uma organização
model OrganizationUnit {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  slug           String
  isDefault      Boolean      @default(false) @map("is_default")
  settings       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deals          Deal[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("organization_units")
}

/// User - Usuário do sistema
model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  name               String?
  avatarUrl          String?              @map("avatar_url")
  passwordHash       String?              @map("password_hash")
  /// Legado: campo usado na migração do Supabase Cloud. Preferir usar memberships.
  organizationId     String?              @map("organization_id") @db.Uuid
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  activities         DealActivity[]       @relation("PerformedActivities")
  assignedDeals      Deal[]               @relation("AssignedDeals")
  memberships        OrganizationMember[]
  ownedOrganizations Organization[]       @relation("OwnedOrganizations")
  assignedSchedules  Schedule[]           @relation("AssignedSchedules")
  /// Relação legada com organização (via organization_id)
  legacyOrganization Organization?        @relation("LegacyUserOrganization", fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("users")
}

/// WhatsAppInstance - Instância WhatsApp Business
/// Modelo adaptado para tabela whatsapp_cloud_instances do Aurea
model WhatsAppInstance {
  id                    String                @id @default(uuid())
  agentId               String?               @map("agent_id")
  organizationId        String                @map("organization_id")
  unitId                String?               @map("unit_id")
  wabaId                String?               @map("waba_id")
  phoneNumberId         String?               @map("phone_number_id")
  businessId            String?               @map("business_id")
  displayPhoneNumber    String?               @map("display_phone_number")
  verifiedName          String?               @map("verified_name")
  accessToken           String?               @map("access_token")
  refreshToken          String?               @map("refresh_token")
  status                String                @default("DISCONNECTED") @map("status")
  webhookVerified       Boolean               @default(false) @map("webhook_verified")
  qualityRating         String?               @map("quality_rating")
  messagingLimit        String?               @map("messaging_limit")
  channelType           String?               @map("channel_type")
  scopes                String[]              @map("scopes")
  tokenExpiresAt        DateTime?             @map("token_expires_at")
  lastSyncAt            DateTime?             @map("last_sync_at")
  errorMessage          String?               @map("error_message")
  customFields          Json?                 @map("custom_fields")
  name                  String
  phoneNumber           String                @map("phone_number")
  messagingTier         Int                   @default(1) @map("messaging_tier")
  webhookVerifyToken    String?               @map("webhook_verify_token")
  settings              Json?
  connectedAt           DateTime?             @map("connected_at")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  conversations         Conversation[]
  metaWebhookLogs       MetaWebhookLog[]
  pendingFormDeliveries PendingFormDelivery[]
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs                  WhatsAppLog[]
  templates             WhatsAppTemplate[]

  @@index([organizationId])
  @@index([status])
  @@index([phoneNumber])
  @@index([agentId])
  @@index([unitId])
  @@index([wabaId])
  @@index([phoneNumberId])
  @@map("whatsapp_cloud_instances")
}

/// WhatsAppTemplate - Templates de mensagem
/// Modelo adaptado para tabela whatsapp_cloud_templates do Aurea
model WhatsAppTemplate {
  id          String           @id @default(uuid())
  instanceId  String           @map("instance_id")
  templateId  String?          @unique @map("template_id")
  name        String
  category    String           @map("category")
  language    String           @map("language")
  components  Json             @map("components")
  body        String           @map("body")
  header      String?          @map("header")
  footer      String?          @map("footer")
  status      String           @default("DRAFT") @map("status")
  reason      String?          @map("reason")
  submittedAt DateTime?        @map("submitted_at")
  approvedAt  DateTime?        @map("approved_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  messages    Message[]
  instance    WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([status])
  @@index([category])
  @@index([language])
  @@index([name, instanceId])
  @@map("whatsapp_cloud_templates")
}

/// WhatsAppLog - Logs de eventos e operações
/// Modelo adaptado para tabela whatsapp_cloud_logs do Aurea
model WhatsAppLog {
  id          String           @id @default(uuid())
  instanceId  String           @map("instance_id")
  eventType   String           @map("event_type")
  payload     Json             @map("payload")
  level       String?          @map("level")
  processed   Boolean          @default(false) @map("processed")
  processedAt DateTime?        @map("processed_at")
  error       String?          @map("error_message")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  type        String           @default("")
  instance    WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([type])
  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("whatsapp_cloud_logs")
}

/// Contact - Contatos unificados (WhatsApp, Instagram, etc)
model Contact {
  id                String                    @id @default(uuid())
  organizationId    String                    @map("organization_id")
  phone             String
  name              String?
  avatarUrl         String?                   @map("avatar_url")
  metadata          Json?
  tags              String[]
  leadScore         Int                       @default(0) @map("lead_score")
  status            ContactStatus             @default(ACTIVE)
  lastInteractionAt DateTime?                 @map("last_interaction_at")
  deletedAt         DateTime?                 @map("deleted_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  customFieldValues ContactCustomFieldValue[]
  contactTags       ContactTag[]
  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations     Conversation[]
  deals             Deal[]
  listContacts      ListContact[]
  messages          Message[]
  schedules         Schedule[]
  transcriptions    Transcription[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([status])
  @@index([tags])
  @@index([leadScore])
  @@index([deletedAt])
  @@map("contacts")
}

/// Conversation - Conversas (janela de 24h)
model Conversation {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  instanceId     String             @map("instance_id")
  contactId      String             @map("contact_id")
  conversationId String?            @unique @map("conversation_id")
  type           ConversationType
  status         ConversationStatus @default(ACTIVE)
  windowStart    DateTime           @map("window_start")
  windowEnd      DateTime           @map("window_end")
  lastMessageAt  DateTime?          @map("last_message_at")
  messageCount   Int                @default(0) @map("message_count")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  contact        Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  instance       WhatsAppInstance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       Message[]
  transcriptions Transcription[]

  @@index([organizationId])
  @@index([instanceId])
  @@index([contactId])
  @@index([status])
  @@index([windowEnd])
  @@index([organizationId, contactId])
  @@map("conversations")
}

/// Message - Mensagens
model Message {
  id             String            @id @default(uuid())
  conversationId String            @map("conversation_id")
  contactId      String            @map("contact_id")
  messageId      String?           @unique @map("message_id")
  direction      MessageDirection
  type           MessageType
  content        String
  mediaUrl       String?           @map("media_url")
  caption        String?
  templateId     String?           @map("template_id")
  status         MessageStatus     @default(SENT)
  sentAt         DateTime?         @map("sent_at")
  deliveredAt    DateTime?         @map("delivered_at")
  readAt         DateTime?         @map("read_at")
  failedAt       DateTime?         @map("failed_at")
  failedReason   String?           @map("failed_reason")
  metadata       Json?
  createdAt      DateTime          @default(now()) @map("created_at")
  contact        Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template       WhatsAppTemplate? @relation(fields: [templateId], references: [id])

  @@index([conversationId])
  @@index([contactId])
  @@index([messageId])
  @@index([status])
  @@index([direction])
  @@index([type])
  @@index([createdAt])
  @@index([conversationId, createdAt])
  @@map("messages")
}

/// InstagramInstance - Instância Instagram Business
model InstagramInstance {
  id                         String                  @id @default(uuid())
  organizationId             String                  @map("organization_id")
  name                       String
  pageId                     String                  @map("page_id")
  instagramBusinessAccountId String                  @map("instagram_business_account_id")
  accessToken                String?                 @map("access_token")
  refreshToken               String?                 @map("refresh_token")
  tokenExpiresAt             DateTime?               @map("token_expires_at")
  username                   String?
  profilePictureUrl          String?                 @map("profile_picture_url")
  status                     InstagramInstanceStatus @default(DISCONNECTED)
  webhookVerifyToken         String?                 @map("webhook_verify_token")
  settings                   Json?
  lastSyncAt                 DateTime?               @map("last_sync_at")
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @updatedAt @map("updated_at")
  connectedAt                DateTime?               @map("connected_at")
  organization               Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metaWebhookLogs            MetaWebhookLog[]

  @@index([organizationId])
  @@index([status])
  @@index([instagramBusinessAccountId])
  @@map("instagram_instances")
}

/// PipelineStage - Etapas do funil de vendas
model PipelineStage {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  position       Int
  color          String?
  probability    Int          @default(0)
  isDefault      Boolean      @default(false) @map("is_default")
  isClosed       Boolean      @default(false) @map("is_closed")
  settings       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deals          Deal[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([position])
  @@map("pipeline_stages")
}

/// Deal - Oportunidades no pipeline
model Deal {
  id                String                 @id @default(uuid())
  organizationId    String                 @map("organization_id")
  contactId         String                 @map("contact_id")
  stageId           String                 @map("stage_id")
  unitId            String?                @map("unit_id")
  title             String
  description       String?
  value             Decimal                @default(0) @db.Decimal(15, 2)
  amount            Decimal?               @db.Decimal(15, 2)
  currency          String?                @default("BRL")
  leadScore         Int?                   @default(0) @map("lead_score")
  probability       Int                    @default(0)
  expectedCloseDate DateTime?              @map("expected_close_date")
  actualCloseDate   DateTime?              @map("actual_close_date")
  assignedTo        String?                @map("assigned_to")
  createdBy         String                 @map("created_by")
  status            DealStatus             @default(OPEN)
  priority          DealPriority           @default(MEDIUM)
  source            String?
  sourceId          String?                @map("source_id")
  tags              String[]
  metadata          Json?
  lostReason        String?                @map("lost_reason")
  lostAt            DateTime?              @map("lost_at")
  closedLostAt      DateTime?              @map("closed_lost_at")
  closedWonAt       DateTime?              @map("closed_won_at")
  channel           ChannelType            @default(OTHER)
  utmSource         String?                @map("utm_source")
  estimatedValue    Float                  @default(0) @map("estimated_value")
  qualifiedAt       DateTime?              @map("qualified_at")
  proposalSentAt    DateTime?              @map("proposal_sent_at")
  negotiationAt     DateTime?              @map("negotiation_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @default(now()) @map("updated_at")
  activities        DealActivity[]
  assignee          User?                  @relation("AssignedDeals", fields: [assignedTo], references: [id])
  contact           Contact                @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage             PipelineStage          @relation(fields: [stageId], references: [id])
  unit              OrganizationUnit?      @relation(fields: [unitId], references: [id])
  stageHistory      PipelineStageHistory[]
  schedules         Schedule[]

  @@index([organizationId])
  @@index([contactId])
  @@index([stageId])
  @@index([assignedTo])
  @@index([status])
  @@index([leadScore])
  @@index([expectedCloseDate])
  @@index([status, createdAt])
  @@index([channel, createdAt])
  @@index([qualifiedAt])
  @@index([proposalSentAt])
  @@map("deals")
}

model PipelineStageHistory {
  id        String    @id @default(uuid())
  dealId    String    @map("deal_id")
  stage     String
  enteredAt DateTime  @default(now()) @map("entered_at")
  exitedAt  DateTime? @map("exited_at")
  duration  Int?
  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([stage, enteredAt])
  @@index([exitedAt])
  @@map("pipeline_stage_history")
}

model MonthlyGoal {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  month           Int
  year            Int
  revenueGoal     Float    @default(0) @map("revenue_goal")
  dealsGoal       Int      @default(0) @map("deals_goal")
  leadsGoal       Int      @default(0) @map("leads_goal")
  conversionGoal  Float    @default(0) @map("conversion_goal")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, year, month], name: "organizationId_year_month")
  @@index([organizationId])
  @@index([month])
  @@index([year])
  @@map("monthly_goals")
}

model DashboardMetricCache {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  metricType     String   @map("metric_type")
  period         String
  data           Json
  calculatedAt   DateTime @default(now()) @map("calculated_at")
  expiresAt      DateTime @map("expires_at")

  @@unique([organizationId, metricType, period])
  @@index([expiresAt])
  @@index([organizationId, metricType])
  @@map("dashboard_metric_cache")
}

/// DealActivity - Atividades e timeline do deal
model DealActivity {
  id           String       @id @default(uuid())
  dealId       String       @map("deal_id")
  type         ActivityType
  title        String
  content      String?
  metadata     Json?
  scoreImpact  Int          @default(0) @map("score_impact")
  performedBy  String?      @map("performed_by")
  automationId String?      @map("automation_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  deal         Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  performer    User?        @relation("PerformedActivities", fields: [performedBy], references: [id])

  @@index([dealId])
  @@index([type])
  @@index([performedBy])
  @@index([createdAt])
  @@map("deal_activities")
}

/// MetaWebhookLog - Logs de webhooks da Meta (WhatsApp/Instagram)
/// Tabela unificada para rastrear todos os eventos de webhook
model MetaWebhookLog {
  id                  String             @id @default(uuid())
  organizationId      String             @map("organization_id")
  whatsappInstanceId  String?            @map("whatsapp_instance_id")
  instagramInstanceId String?            @map("instagram_instance_id")
  eventType           String             @map("event_type")
  payload             Json?
  forwardedToN8n      Boolean            @default(false) @map("forwarded_to_n8n")
  processed           Boolean            @default(false)
  processedAt         DateTime?          @map("processed_at")
  errorMessage        String?            @map("error_message")
  createdAt           DateTime           @default(now()) @map("created_at")
  instagramInstance   InstagramInstance? @relation(fields: [instagramInstanceId], references: [id])
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappInstance    WhatsAppInstance?  @relation(fields: [whatsappInstanceId], references: [id])

  @@index([organizationId])
  @@index([whatsappInstanceId])
  @@index([instagramInstanceId])
  @@index([eventType])
  @@index([createdAt])
  @@index([processed])
  @@map("meta_webhook_logs")
}

model Schedule {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  type           ScheduleType
  title          String
  description    String?
  contactId      String?        @map("contact_id")
  dealId         String?        @map("deal_id")
  assignedTo     String?        @map("assigned_to")
  startTime      DateTime       @map("start_time")
  endTime        DateTime       @map("end_time")
  completedAt    DateTime?      @map("completed_at")
  status         ScheduleStatus @default(pending)
  location       String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  assignee       User?          @relation("AssignedSchedules", fields: [assignedTo], references: [id])
  contact        Contact?       @relation(fields: [contactId], references: [id])
  deal           Deal?          @relation(fields: [dealId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
  @@index([dealId])
  @@index([assignedTo])
  @@index([status])
  @@index([startTime])
  @@index([organizationId, startTime])
  @@map("schedules")
}

/// Tag - Tags para categorização de contatos
model Tag {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  color          String       @default("#6366f1")
  description    String?
  source         String       @default("manual")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  contactTags    ContactTag[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([name])
  @@map("tags")
}

/// ContactTag - Relacionamento many-to-many entre Contact e Tag
model ContactTag {
  contactId  String   @map("contact_id")
  tagId      String   @map("tag_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
  @@map("contact_tags")
}

/// List - Listas de contatos (estáticas ou dinâmicas)
model List {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  name           String
  description    String?
  filters        Json          @default("{}")
  isDynamic      Boolean       @default(false) @map("is_dynamic")
  contactCount   Int           @default(0) @map("contact_count")
  createdBy      String?       @map("created_by")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  listContacts   ListContact[]
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("lists")
}

/// ListContact - Relacionamento many-to-many entre List e Contact
model ListContact {
  listId    String   @map("list_id")
  contactId String   @map("contact_id")
  addedAt   DateTime @default(now()) @map("added_at")
  addedBy   String?  @map("added_by")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([listId])
  @@index([contactId])
  @@map("list_contacts")
}

/// CustomFieldDefinition - Definições de campos customizados
model CustomFieldDefinition {
  id             String                    @id @default(uuid())
  organizationId String                    @map("organization_id")
  name           String
  key            String
  description    String?
  type           String
  required       Boolean                   @default(false)
  options        Json                      @default("[]")
  displayOrder   Int                       @default(0) @map("display_order")
  isActive       Boolean                   @default(true) @map("is_active")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  values         ContactCustomFieldValue[]
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([isActive])
  @@map("custom_field_definitions")
}

/// ContactCustomFieldValue - Valores de campos customizados para contatos
model ContactCustomFieldValue {
  id        String                @id @default(uuid())
  contactId String                @map("contact_id")
  fieldId   String                @map("field_id")
  value     String?
  updatedAt DateTime              @updatedAt @map("updated_at")
  contact   Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  field     CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldId])
  @@index([contactId])
  @@index([fieldId])
  @@map("contact_custom_field_values")
}

/// Segment - Segmentos dinâmicos de contatos
model Segment {
  id               String       @id @default(uuid())
  organizationId   String       @map("organization_id")
  name             String
  description      String?
  rules            Json         @default("[]")
  contactCount     Int          @default(0) @map("contact_count")
  lastCalculatedAt DateTime?    @map("last_calculated_at")
  createdBy        String?      @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("segments")
}

model PipelineTemplate {
  id          String                  @id @default(uuid())
  name        String
  category    String                  @unique
  description String?
  isDefault   Boolean                 @default(false) @map("is_default")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  stages      PipelineTemplateStage[]

  @@index([category])
  @@index([isDefault])
  @@map("pipeline_templates")
}

model PipelineTemplateStage {
  id          String           @id @default(uuid())
  templateId  String           @map("template_id")
  name        String
  position    Int
  color       String?
  probability Int              @default(0)
  isClosed    Boolean          @default(false) @map("is_closed")
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  template    PipelineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([position])
  @@map("pipeline_template_stages")
}

model AiInsight {
  id                String          @id @default(uuid())
  organizationId    String          @map("organization_id")
  type              AiInsightType
  category          String
  title             String
  description       String
  value             String?
  confidence        Float?          @default(0.85)
  metadata          Json?
  relatedContactIds String[]        @map("related_contact_ids")
  relatedDealIds    String[]        @map("related_deal_ids")
  status            AiInsightStatus @default(ACTIVE)
  action            String?         @map("action_text")
  actionUrl         String?         @map("action_url")
  clickedAt         DateTime?       @map("clicked_at")
  dismissedAt       DateTime?       @map("dismissed_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  expiresAt         DateTime?       @map("expires_at")
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("ai_insights")
}

model Transcription {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  contactId      String?             @map("contact_id")
  conversationId String?             @map("conversation_id")
  source         TranscriptionSource
  sourceId       String?             @map("source_id")
  title          String?
  duration       Int?
  status         TranscriptionStatus @default(PENDING)
  transcript     String?
  summary        String?
  sentiment      String?
  sentimentScore Float?              @map("sentiment_score")
  objections     Json?
  keyTopics      String[]            @map("key_topics")
  actionItems    String[]            @map("action_items")
  converted      Boolean?            @default(false)
  resolutionDays Int?                @map("resolution_days")
  dealId         String?             @map("deal_id")
  audioUrl       String?             @map("audio_url")
  audioSize      Int?                @map("audio_size")
  audioFormat    String?             @map("audio_format")
  recordedAt     DateTime?           @map("recorded_at")
  processedAt    DateTime?           @map("processed_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  contact        Contact?            @relation(fields: [contactId], references: [id])
  conversation   Conversation?       @relation(fields: [conversationId], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
  @@index([conversationId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([converted])
  @@map("transcriptions")
}

/// Integration - Integrações de terceiros (Zapier, n8n, Make, etc)
model Integration {
  id                 String              @id @default(uuid())
  organizationId     String              @map("organization_id")
  type               String
  name               String
  status             String              @default("inactive")
  config             Json?
  connectedAt        DateTime?           @map("connected_at")
  lastSyncAt         DateTime?           @map("last_sync_at")
  errorMessage       String?             @map("error_message")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  integrationConfigs IntegrationConfig[]
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@map("integrations")
}

/// IntegrationConfig - Configurações específicas por integração
/// Permite armazenar múltiplas configurações chave-valor para cada integração
model IntegrationConfig {
  id            String      @id @default(uuid())
  integrationId String      @map("integration_id")
  key           String
  value         String
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, key])
  @@index([integrationId])
  @@index([key])
  @@map("integration_configs")
}

model IntegrationActivityLog {
  id              String                    @id @default(uuid())
  organizationId  String                    @map("organization_id")
  integrationType IntegrationType           @map("integration_type")
  instanceId      String?                   @map("instance_id")
  activityType    IntegrationActivityType   @map("activity_type")
  status          IntegrationActivityStatus @default(SUCCESS)
  title           String
  description     String?
  requestPayload  Json?                     @map("request_payload")
  responsePayload Json?                     @map("response_payload")
  errorMessage    String?                   @map("error_message")
  errorCode       String?                   @map("error_code")
  contactId       String?                   @map("contact_id")
  dealId          String?                   @map("deal_id")
  messageId       String?                   @map("message_id")
  sourceIp        String?                   @map("source_ip")
  userAgent       String?                   @map("user_agent")
  durationMs      Int?                      @map("duration_ms")
  retryCount      Int                       @default(0) @map("retry_count")
  maxRetries      Int                       @default(3) @map("max_retries")
  createdAt       DateTime                  @default(now()) @map("created_at")
  completedAt     DateTime?                 @map("completed_at")
  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([integrationType])
  @@index([instanceId])
  @@index([activityType])
  @@index([status])
  @@index([contactId])
  @@index([createdAt])
  @@map("integration_activity_logs")
}

/// Plan - Planos de assinatura
model Plan {
  id            String         @id @default(uuid())
  name          String
  description   String?
  priceCents    Int            @map("price_cents")
  interval      String
  features      Json?
  limits        Json?
  status        String         @default("active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  subscriptions Subscription[]

  @@index([status])
  @@index([interval])
  @@map("plans")
}

/// Subscription - Assinaturas
model Subscription {
  id                 String       @id @default(uuid())
  organizationId     String       @map("organization_id")
  planId             String       @map("plan_id")
  status             String       @default("active")
  currentPeriodStart DateTime     @map("current_period_start")
  currentPeriodEnd   DateTime     @map("current_period_end")
  canceledAt         DateTime?    @map("canceled_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  invoices           Invoice[]
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

/// Invoice - Faturas
model Invoice {
  id              String       @id @default(uuid())
  subscriptionId  String       @map("subscription_id")
  organizationId  String       @map("organization_id")
  amountCents     Int          @map("amount_cents")
  status          String       @default("pending")
  dueDate         DateTime     @map("due_date")
  paidAt          DateTime?    @map("paid_at")
  invoiceUrl      String?      @map("invoice_url")
  stripeInvoiceId String?      @map("stripe_invoice_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  charges         Charge[]
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@index([stripeInvoiceId])
  @@map("invoices")
}

/// Charge - Cobranças
model Charge {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  invoiceId      String?      @map("invoice_id")
  amountCents    Int          @map("amount_cents")
  description    String?
  status         String       @default("pending")
  paymentMethod  String?      @map("payment_method")
  paidAt         DateTime?    @map("paid_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@index([status])
  @@index([paidAt])
  @@map("charges")
}

/// Coupon - Cupons
model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  description     String?
  discountPercent Int?     @map("discount_percent")
  discountCents   Int?     @map("discount_cents")
  validFrom       DateTime @map("valid_from")
  validUntil      DateTime @map("valid_until")
  maxUses         Int?     @map("max_uses")
  usesCount       Int      @default(0) @map("uses_count")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([status])
  @@index([validFrom, validUntil])
  @@map("coupons")
}

/// PendingFormDelivery - Entregas pendentes de formulários do Plano de Ação
/// Rastreia o estado de envio de PDFs via WhatsApp após template ser entregue
model PendingFormDelivery {
  id               String                    @id @default(cuid())
  messageId        String                    @unique
  organizationId   String
  instanceId       String
  phone            String
  pdfUrl           String
  pdfFilename      String
  mediaId          String?
  templateName     String
  templateLanguage String                    @default("pt_BR")
  leadName         String?
  leadEmail        String?
  dossieId         String?
  alunoId          String?
  status           PendingFormDeliveryStatus @default(WAITING)
  retryCount       Int                       @default(0)
  isCancelled      Boolean                   @default(false)
  cancelledAt      DateTime?
  cancelledBy      String?
  reprocessedFrom  String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  expiresAt        DateTime
  completedAt      DateTime?
  errorMessage     String?
  lastErrorAt      DateTime?
  instance         WhatsAppInstance          @relation(fields: [instanceId], references: [id])
  organization     Organization              @relation(fields: [organizationId], references: [id])

  @@index([messageId])
  @@index([organizationId])
  @@index([status])
  @@index([expiresAt])
  @@index([dossieId])
  @@index([createdAt])
  @@map("pending_form_deliveries")
}

