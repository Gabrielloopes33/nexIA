# ============================
# Stripe Configuration
# ============================

# Secret Key (obtenha em: https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...

# Publishable Key (para frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook Secret (configure em: https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (crie em: https://dashboard.stripe.com/products)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_...
STRIPE_BUSINESS_YEARLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# ============================
# Facebook / WhatsApp Configuration
# ============================

# Facebook App ID (obtenha em: https://developers.facebook.com/apps)
FACEBOOK_APP_ID=your_app_id_here

# Facebook App Secret (obtenha em: https://developers.facebook.com/apps > Configurações > Básico)
FACEBOOK_APP_SECRET=your_app_secret_here

# Embedded Signup Configuration ID (crie em: https://developers.facebook.com/apps > WhatsApp > Configuração da API)
FACEBOOK_EMBEDDED_SIGNUP_CONFIG_ID=your_config_id_here

# Facebook Graph API Version
FACEBOOK_API_VERSION=v18.0

# Redirect URI for OAuth callback (deve corresponder à configuração no Facebook App)
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/whatsapp/embedded-signup/callback

# ============================
# App Configuration
# ============================

# URL da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ambiente
NODE_ENV=development
