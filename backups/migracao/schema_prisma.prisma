// ============================================
// AI INSIGHTS - Análises de IA
// ============================================

enum AiInsightType {
  PREDICTION
  ALERT
  RECOMMENDATION
  DISCOVERY
}

enum AiInsightStatus {
  ACTIVE
  DISMISSED
  ARCHIVED
}

model AiInsight {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type        AiInsightType
  category    String // conversion, pipeline, engagement, etc
  title       String
  description String
  value       String? // Valor formatado (ex: "23 leads", "R$ 87.500")
  confidence  Float?        @default(0.85) // Nível de confiança (0-1)

  // Dados estruturados
  metadata Json?

  // Referências relacionadas
  relatedContactIds String[] @map("related_contact_ids") // IDs de contatos relacionados
  relatedDealIds    String[] @map("related_deal_ids") // IDs de deals relacionados

  // Status e ações
  status      AiInsightStatus @default(ACTIVE)
  action      String?         @map("action_text") // Texto da ação sugerida
  actionUrl   String?         @map("action_url")
  clickedAt   DateTime?       @map("clicked_at")
  dismissedAt DateTime?       @map("dismissed_at")

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at") // Expiração do insight

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("ai_insights")
}

// ============================================
// TRANSCRIPTIONS - Transcrições de calls/áudios
// ============================================

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TranscriptionSource {
  WHATSAPP_CALL
  WHATSAPP_AUDIO
  PHONE_CALL
  MEETING
  UPLOAD
}

model Transcription {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Referências
  contactId String?  @map("contact_id")
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  conversationId String?       @map("conversation_id")
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  // Dados da transcrição
  source   TranscriptionSource
  sourceId String?             @map("source_id") // ID da mensagem/call no sistema de origem
  title    String?
  duration Int? // Duração em segundos

  // Status
  status TranscriptionStatus @default(PENDING)

  // Conteúdo
  transcript String? @db.Text
  summary    String? @db.Text

  // Análise de IA
  sentiment      String? // positive, negative, neutral
  sentimentScore Float?   @map("sentiment_score") // -1 a 1
  objections     Json? // Array de objeções detectadas
  keyTopics      String[] @map("key_topics")
  actionItems    String[] @map("action_items")

  // Resultado comercial
  converted      Boolean? @default(false)
  resolutionDays Int?     @map("resolution_days")
  dealId         String?  @map("deal_id")

  // Arquivo de áudio
  audioUrl    String? @map("audio_url")
  audioSize   Int?    @map("audio_size") // bytes
  audioFormat String? @map("audio_format") // mp3, wav, ogg

  // Timestamps
  recordedAt  DateTime? @map("recorded_at")
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([conversationId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([converted])
  @@map("transcriptions")
}

// ============================================
// INTEGRATIONS - Sprint 4 (Mock → Supabase)
// ============================================

/// Integration - Integrações de terceiros (Zapier, n8n, Make, etc)
model Integration {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Tipo de integração
  type String // zapier, n8n, make, hubspot, google_sheets, slack, typebot, whatsapp, instagram, webhook

  // Identificação
  name String

  // Status
  status String @default("inactive") // active, inactive, error

  // Configurações específicas (JSON flexível)
  config Json?

  // Timestamps de conexão e sync
  connectedAt DateTime? @map("connected_at")
  lastSyncAt  DateTime? @map("last_sync_at")

  // Erro (quando status = error)
  errorMessage String? @map("error_message")

  // Relacionamentos
  integrationConfigs IntegrationConfig[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@map("integrations")
}

/// IntegrationConfig - Configurações específicas por integração
/// Permite armazenar múltiplas configurações chave-valor para cada integração
model IntegrationConfig {
  id String @id @default(uuid())

  integrationId String      @map("integration_id")
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // Chave e valor da configuração
  key   String
  value String

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([integrationId, key])
  @@index([integrationId])
  @@index([key])
  @@map("integration_configs")
}

// ============================================
// INTEGRATION ACTIVITY LOGS - Logs de integrações
// ============================================

enum IntegrationType {
  WHATSAPP
  INSTAGRAM
  N8N
  MAKE
  ZAPIER
  WEBHOOK
  API
}

enum IntegrationActivityType {
  AUTH_CONNECTED
  AUTH_DISCONNECTED
  AUTH_REFRESHED
  AUTH_FAILED
  WEBHOOK_RECEIVED
  WEBHOOK_SENT
  MESSAGE_SENT
  MESSAGE_RECEIVED
  SYNC_STARTED
  SYNC_COMPLETED
  SYNC_FAILED
  TEMPLATE_SENT
  ERROR
  CONFIG_UPDATED
}

enum IntegrationActivityStatus {
  SUCCESS
  PENDING
  FAILED
  WARNING
}

model IntegrationActivityLog {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Integração
  integrationType IntegrationType @map("integration_type")
  instanceId      String?         @map("instance_id") // ID da instância (WhatsApp/Instagram)

  // Atividade
  activityType IntegrationActivityType   @map("activity_type")
  status       IntegrationActivityStatus @default(SUCCESS)

  // Descrição e detalhes
  title       String
  description String?

  // Dados da requisição/resposta
  requestPayload  Json?   @map("request_payload")
  responsePayload Json?   @map("response_payload")
  errorMessage    String? @map("error_message")
  errorCode       String? @map("error_code")

  // Referências relacionadas
  contactId String? @map("contact_id")
  dealId    String? @map("deal_id")
  messageId String? @map("message_id")

  // Metadados
  sourceIp   String? @map("source_ip")
  userAgent  String? @map("user_agent")
  durationMs Int?    @map("duration_ms") // Tempo de execução

  // Retry
  retryCount Int @default(0) @map("retry_count")
  maxRetries Int @default(3) @map("max_retries")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([organizationId])
  @@index([integrationType])
  @@index([instanceId])
  @@index([activityType])
  @@index([status])
  @@index([contactId])
  @@index([createdAt])
  @@map("integration_activity_logs")
}

// ============================================
// SPRINT 5: BILLING & SUBSCRIPTIONS - Cobranças e Assinaturas
// ============================================

/// Plan - Planos de assinatura
model Plan {
  id          String @id @default(uuid())
  name        String
  description String?

  priceCents Int    @map("price_cents")
  interval   String // 'monthly' | 'yearly'

  features Json?
  limits   Json?

  status String @default("active") // 'active' | 'inactive'

  // Relacionamentos
  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([interval])
  @@map("plans")
}

/// Subscription - Assinaturas
model Subscription {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  planId String @map("plan_id")
  plan   Plan   @relation(fields: [planId], references: [id])

  status String @default("active") // 'active' | 'canceled' | 'past_due'

  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  canceledAt         DateTime? @map("canceled_at")

  // Relacionamentos
  invoices Invoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

/// Invoice - Faturas
model Invoice {
  id String @id @default(uuid())

  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  amountCents Int @map("amount_cents")

  status String @default("pending") // 'pending' | 'paid' | 'failed'

  dueDate DateTime  @map("due_date")
  paidAt  DateTime? @map("paid_at")

  invoiceUrl      String? @map("invoice_url")
  stripeInvoiceId String? @map("stripe_invoice_id")

  // Relacionamentos
  charges Charge[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@index([stripeInvoiceId])
  @@map("invoices")
}

/// Charge - Cobranças
model Charge {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invoiceId String?  @map("invoice_id")
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  amountCents Int @map("amount_cents")
  description String?

  status String @default("pending") // 'pending' | 'paid' | 'failed'

  paymentMethod String?   @map("payment_method")
  paidAt        DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([invoiceId])
  @@index([status])
  @@index([paidAt])
  @@map("charges")
}

/// Coupon - Cupons
model Coupon {
  id String @id @default(uuid())

  code        String  @unique
  description String?

  discountPercent Int? @map("discount_percent")
  discountCents   Int? @map("discount_cents")

  validFrom  DateTime @map("valid_from")
  validUntil DateTime @map("valid_until")

  maxUses   Int? @map("max_uses")
  usesCount Int  @default(0) @map("uses_count")

  status String @default("active") // 'active' | 'inactive'

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([status])
  @@index([validFrom, validUntil])
  @@map("coupons")
}

// ============================================
// FORM DELIVERY - Integração com Plano de Ação
// ============================================

enum PendingFormDeliveryStatus {
  WAITING // Aguardando confirmação de entrega do template
  PROCESSING // Enviando PDF (upload + send)
  COMPLETED // PDF entregue com sucesso
  FAILED // Erro após tentativas
  EXPIRED // PDF URL expirou (24h)
  CANCELLED // Cancelado manualmente
}

/// PendingFormDelivery - Entregas pendentes de formulários do Plano de Ação
/// Rastreia o estado de envio de PDFs via WhatsApp após template ser entregue
model PendingFormDelivery {
  id        String @id @default(cuid())
  messageId String @unique // ID retornado pela Meta ao enviar template

  // Identificação
  organizationId String
  instanceId     String
  phone          String

  // Documento
  pdfUrl      String // URL do PDF no sistema externo
  pdfFilename String
  mediaId     String? // ID do documento na Meta (após upload)

  // Template
  templateName     String
  templateLanguage String @default("pt_BR")

  // Lead (denormalizado para rastreamento)
  leadName  String?
  leadEmail String?

  // Rastreamento externo
  dossieId String? // ID do dossié no plano-de-acao
  alunoId  String? // ID do aluno no plano-de-acao

  // Status
  status     PendingFormDeliveryStatus @default(WAITING)
  retryCount Int                       @default(0)

  // Controle de reprocessamento
  isCancelled     Boolean   @default(false)
  cancelledAt     DateTime?
  cancelledBy     String?
  reprocessedFrom String? // ID original se for reprocessamento

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime // TTL (24h após createdAt)
  completedAt DateTime?

  // Error tracking
  errorMessage String?
  lastErrorAt  DateTime?

  // Relações
  organization Organization     @relation(fields: [organizationId], references: [id])
  instance     WhatsAppInstance @relation(fields: [instanceId], references: [id])

  @@index([messageId])
  @@index([organizationId])
  @@index([status])
  @@index([expiresAt])
  @@index([dossieId])
  @@index([createdAt])
  @@map("pending_form_deliveries")
}
