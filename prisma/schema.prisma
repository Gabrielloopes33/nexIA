// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELOS DO WHATSAPP BUSINESS API
// ============================================

/**
 * WhatsApp Business Account (WABA)
 * Representa uma conta de negócio do WhatsApp na API da Meta
 */
model WhatsAppBusinessAccount {
  id              String   @id @default(uuid())
  wabaId          String   @unique @map("waba_id") // ID da Meta
  name            String
  displayName     String?  @map("display_name")
  timezoneId      String?  @map("timezone_id")
  messageTemplateNamespace String? @map("message_template_namespace")
  
  // Relacionamentos
  phoneNumbers    WhatsAppPhoneNumber[]
  messageTemplates MessageTemplate[]
  conversations   WhatsAppConversation[]
  webhookEvents   WebhookEvent[]
  analytics       WhatsAppAnalytics[]
  
  // Status
  status          WhatsAppStatus @default(NOT_CONNECTED)
  qualityRating   QualityRating? @map("quality_rating")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  connectedAt     DateTime? @map("connected_at")
  
  // Usuário/Workspace
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])

  @@map("whatsapp_business_accounts")
  @@index([userId])
  @@index([status])
  @@index([wabaId])
}

/**
 * Números de Telefone do WhatsApp Business
 * Cada número associado a uma WABA
 */
model WhatsAppPhoneNumber {
  id                String   @id @default(uuid())
  phoneNumberId     String   @unique @map("phone_number_id") // ID da Meta
  displayPhoneNumber String  @map("display_phone_number")
  verifiedName      String?  @map("verified_name")
  
  // Status
  status            PhoneStatus @default(PENDING)
  qualityRating     QualityRating @default(UNKNOWN) @map("quality_rating")
  
  // Tier e limites
  messagingTier     Int      @default(1) @map("messaging_tier") // 1, 2, 3...
  messagingLimit    Int      @default(250) @map("messaging_limit") // mensagens/dia
  
  // Configurações
  isDefault         Boolean  @default(false) @map("is_default")
  
  // Relacionamentos
  wabaId            String   @map("waba_id")
  waba              WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id], onDelete: Cascade)
  
  conversations     WhatsAppConversation[]
  
  // Código de verificação (temporário)
  verificationCode  String?  @map("verification_code")
  codeExpiresAt     DateTime? @map("code_expires_at")
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_phone_numbers")
  @@index([wabaId])
  @@index([status])
  @@index([phoneNumberId])
  @@index([displayPhoneNumber])
}

/**
 * Templates de Mensagem
 * Templates aprovados pela Meta para envio de mensagens
 */
model MessageTemplate {
  id              String   @id @default(uuid())
  templateId      String?  @unique @map("template_id") // ID da Meta (após aprovação)
  name            String
  category        TemplateCategory
  language        String   // pt_BR, en_US, etc
  
  // Componentes do template (JSON)
  components      Json     // Header, Body, Footer, Buttons
  
  // Status
  status          TemplateStatus @default(DRAFT)
  reason          String?  // Motivo da rejeição
  
  // Conteúdo
  body            String
  header          String?
  footer          String?
  
  // Relacionamentos
  wabaId          String   @map("waba_id")
  waba            WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id], onDelete: Cascade)
  
  messages        WhatsAppMessage[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  submittedAt     DateTime? @map("submitted_at")
  approvedAt      DateTime? @map("approved_at")

  @@map("message_templates")
  @@index([wabaId])
  @@index([status])
  @@index([category])
  @@index([language])
  @@index([name, wabaId])
}

/**
 * Conversas (24h window)
 * Janela de conversação de 24 horas com cada contato
 */
model WhatsAppConversation {
  id              String   @id @default(uuid())
  conversationId  String?  @unique @map("conversation_id") // ID da Meta
  
  // Contato
  contactPhone    String   @map("contact_phone")
  contactName     String?  @map("contact_name")
  
  // Tipo
  type            ConversationType
  
  // Status
  status          ConversationStatus @default(ACTIVE)
  
  // Janela de 24h
  windowStart     DateTime @map("window_start")
  windowEnd       DateTime @map("window_end")
  
  // Relacionamentos
  wabaId          String   @map("waba_id")
  waba            WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id], onDelete: Cascade)
  phoneNumberId   String   @map("phone_number_id")
  phoneNumber     WhatsAppPhoneNumber @relation(fields: [phoneNumberId], references: [id])
  
  messages        WhatsAppMessage[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_conversations")
  @@index([wabaId])
  @@index([contactPhone])
  @@index([status])
  @@index([windowEnd])
  @@index([wabaId, contactPhone])
  @@index([phoneNumberId])
}

/**
 * Mensagens
 * Mensagens enviadas e recebidas
 */
model WhatsAppMessage {
  id              String   @id @default(uuid())
  messageId       String?  @unique @map("message_id") // ID da Meta
  
  // Direção
  direction       MessageDirection
  
  // Tipo
  type            MessageType
  
  // Conteúdo
  content         String   // Texto ou JSON para mídia
  mediaUrl        String?  @map("media_url")
  caption         String?
  
  // Status
  status          MessageStatus @default(SENT)
  
  // Timestamps de status
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  readAt          DateTime? @map("read_at")
  failedAt        DateTime? @map("failed_at")
  failedReason    String?  @map("failed_reason")
  
  // Template (se aplicável)
  templateId      String?  @map("template_id")
  template        MessageTemplate? @relation(fields: [templateId], references: [id])
  
  // Relacionamento
  conversationId  String   @map("conversation_id")
  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("whatsapp_messages")
  @@index([conversationId])
  @@index([messageId])
  @@index([status])
  @@index([direction])
  @@index([type])
  @@index([createdAt])
  @@index([conversationId, createdAt])
}

/**
 * Eventos de Webhook
 * Logs de eventos recebidos da API da Meta
 */
model WebhookEvent {
  id              String   @id @default(uuid())
  
  // Tipo do objeto
  objectType      String   @map("object_type") // whatsapp_business_account
  
  // Dados do evento
  eventType       String   @map("event_type") // messages, message_template_status_update, etc
  payload         Json     // Payload completo do evento
  
  // Status de processamento
  processed       Boolean  @default(false)
  processedAt     DateTime? @map("processed_at")
  error           String?
  
  // Relacionamento
  wabaId          String   @map("waba_id")
  waba            WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("webhook_events")
  @@index([wabaId])
  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@index([wabaId, eventType])
}

/**
 * Analytics/Métricas
 * Métricas diárias de uso do WhatsApp Business
 */
model WhatsAppAnalytics {
  id              String   @id @default(uuid())
  
  // Data
  date            DateTime
  
  // Métricas
  conversationsTotal    Int @default(0) @map("conversations_total")
  conversationsUserInitiated Int @default(0) @map("conversations_user_initiated")
  conversationsBusinessInitiated Int @default(0) @map("conversations_business_initiated")
  
  messagesSent      Int @default(0) @map("messages_sent")
  messagesDelivered Int @default(0) @map("messages_delivered")
  messagesRead      Int @default(0) @map("messages_read")
  messagesFailed    Int @default(0) @map("messages_failed")
  
  // Templates
  templatesSent     Int @default(0) @map("templates_sent")
  
  // Qualidade
  qualityRating     QualityRating @default(UNKNOWN) @map("quality_rating")
  
  // Relacionamento
  wabaId            String   @map("waba_id")
  waba              WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id], onDelete: Cascade)

  @@unique([wabaId, date])
  @@index([wabaId, date])
  @@map("whatsapp_analytics")
}

// ============================================
// ENUMS
// ============================================

enum WhatsAppStatus {
  NOT_CONNECTED
  CONNECTING
  CONNECTED
  ERROR
  SUSPENDED
}

enum PhoneStatus {
  PENDING
  VERIFIED
  BLOCKED
  DELETED
}

enum QualityRating {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

enum TemplateCategory {
  AUTHENTICATION
  MARKETING
  UTILITY
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

enum ConversationType {
  USER_INITIATED
  BUSINESS_INITIATED
  REFERRAL_INITIATED
}

enum ConversationStatus {
  ACTIVE
  EXPIRED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  CONTACT
  TEMPLATE
  INTERACTIVE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

// ============================================
// MODELO DE USUÁRIO (REFERÊNCIA)
// ============================================

/**
 * Modelo de User básico para referência
 * Estabelece a relação com as contas WhatsApp Business
 */
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  
  // Relacionamentos
  whatsappAccounts WhatsAppBusinessAccount[]
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}
