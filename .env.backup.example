# ============================================
# NexIA Backup & Monitoring Configuration
# ============================================
# Copie para .env.backup e preencha seus valores!

# ----------------------------------------
# DATABASE (PostgreSQL)
# ----------------------------------------
DB_HOST=49.13.228.89
DB_PORT=5432
DB_NAME=nexia_chat
DB_USER=root
DB_PASSWORD=jVmcWsmLrxHr

# ----------------------------------------
# BACKUP SETTINGS
# ----------------------------------------
# Quando rodar o backup (2h da manhã todo dia)
BACKUP_CRON=0 2 * * *

# Quantos dias manter backups locais
RETENTION_DAYS=7

# Onde salvar backups
BACKUP_DIR=/var/www/nexIA/backups

# ----------------------------------------
# CLOUDFLARE R2 (RECOMENDADO!)
# ----------------------------------------
# 1. Crie conta em https://dash.cloudflare.com
# 2. Vá em R2 → Create bucket → nome: nexia-backups
# 3. R2 → Manage API Tokens → Create API Token
# 4. Copie Access Key ID, Secret Access Key e S3 API endpoint

S3_BUCKET_NAME=nexia-backups
S3_ACCESS_KEY=seu_access_key_aqui
S3_SECRET_KEY=seu_secret_key_aqui
S3_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
S3_REGION=auto
S3_PATH=backups/nexia

# ----------------------------------------
# NOTIFICATIONS (Discord)
# ----------------------------------------
# 1. No Discord: Server Settings → Integrations → Webhooks
# 2. New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# ----------------------------------------
# MONITORING (Grafana)
# ----------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=mude_esta_senha_123
GRAFANA_ROOT_URL=http://49.13.228.89:3001

# ----------------------------------------
# ALERT EMAIL (opcional)
# ----------------------------------------
ALERT_EMAIL_FROM=alertas@nexiachat.com.br
ALERT_EMAIL_TO=seu_email@gmail.com
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_app_password
