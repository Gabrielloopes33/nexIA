enum LostReason {
  PRICE
  COMPETITOR
  TIMING
  NO_BUDGET
  NO_INTEREST
  UNREACHABLE
  OTHER
}

enum ChannelType {
  WHATSAPP_OFFICIAL
  WHATSAPP_UNOFFICIAL
  INSTAGRAM
  MANUAL
  API
}

enum RecoveryPotential {
  HIGH
  MEDIUM
  LOW
  NONE
}

