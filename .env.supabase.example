# ============================================
# SUPABASE SELF-HOSTED - CONFIGURAÇÃO
# ============================================
# Copie este arquivo para .env.supabase e preencha os valores
#
# Gerar secrets seguros:
#   openssl rand -hex 32
#   openssl rand -base64 32
#
# ============================================

# ============================================
# 1. POSTGRESQL
# ============================================
POSTGRES_PASSWORD=sua_senha_segura_aqui_minimo_16_caracteres

# ============================================
# 2. JWT TOKENS (Gerar novos tokens!)
# ============================================
# Use: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Ou gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=sua_chave_jwt_32_caracteres_minimo
JWT_REFRESH_SECRET=sua_chave_refresh_jwt_32_caracteres_minimo
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.seu_token_anon_aqui
SERVICE_ROLE_KEY=eyJhc3NvcnQiOiJzZXJ2aWNlX3JvbGUiLAogICJpc3MiOiAic3VwYWJhc2UiLAogICJpYXQiOiAxNjU2NTEyMDAwLAogICJleHAiOiAxODQxNjg4MDAwCn0.seu_token_service_aqui
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=sua_senha_dashboard_segura

# ============================================
# 3. URLs E ENDPOINTS
# ============================================
SITE_URL=https://nexiachat.com.br
API_EXTERNAL_URL=https://supabase.seudominio.com
SUPABASE_PUBLIC_URL=https://supabase.seudominio.com
ADDITIONAL_REDIRECT_URLS=https://nexiachat.com.br/auth/callback,https://app.nexiachat.com.br/auth/callback

# ============================================
# 4. STUDIO (Interface Web)
# ============================================
STUDIO_DEFAULT_ORGANIZATION=NexIA Labs
STUDIO_DEFAULT_PROJECT=NexIA Production

# ============================================
# 5. EMAIL/SMTP (Configurar para produção!)
# ============================================
ENABLE_EMAIL_SIGNUP=true
MAILER_AUTOCONFIRM=false
MAILER_SECURE_EMAIL_CHANGE_ENABLED=true
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# SMTP Configuration (exemplo com SendGrid)
SMTP_ADMIN_EMAIL=noreply@nexiachat.com.br
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=sua_chave_sendgrid_aqui
SMTP_SENDER_NAME=NexIA
SMTP_MAX_FREQUENCY=1s

# ============================================
# 6. PHONE/SMS (Opcional)
# ============================================
ENABLE_PHONE_SIGNUP=true
SMS_AUTOCONFIRM=false
SMS_MAX_FREQUENCY=5s
SMS_OTP_EXP=6000
SMS_OTP_LENGTH=6
SMS_PROVIDER=
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_MESSAGE_SERVICE_SID=

# ============================================
# 7. PROVIDERS OAuth (Facebook, Google, etc)
# ============================================
EXTERNAL_FACEBOOK_ENABLED=true
EXTERNAL_FACEBOOK_CLIENT_ID=4294607007478015
EXTERNAL_FACEBOOK_SECRET=sua_secret_do_facebook
EXTERNAL_FACEBOOK_REDIRECT_URI=https://supabase.seudominio.com/auth/v1/callback

EXTERNAL_GOOGLE_ENABLED=false
EXTERNAL_GOOGLE_CLIENT_ID=
EXTERNAL_GOOGLE_SECRET=
EXTERNAL_GOOGLE_REDIRECT_URI=https://supabase.seudominio.com/auth/v1/callback

EXTERNAL_GITHUB_ENABLED=false
EXTERNAL_GITHUB_CLIENT_ID=
EXTERNAL_GITHUB_SECRET=
EXTERNAL_GITHUB_REDIRECT_URI=https://supabase.seudominio.com/auth/v1/callback

# ============================================
# 8. STORAGE
# ============================================
STORAGE_REGION=us-east-1
STORAGE_S3_BUCKET=
STORAGE_S3_ENDPOINT=
STORAGE_S3_PROTOCOL=https
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
UPLOAD_FILE_SIZE_LIMIT=52428800
UPLOAD_SIGNED_URL_EXPIRATION_TIME=120
IMAGE_TRANSFORMATION_ENABLED=true
STORAGE_ENCRYPTION_KEY=

# ============================================
# 9. SEGURANÇA
# ============================================
DISABLE_SIGNUP=false
ENABLE_ANONYMOUS_USERS=false
JWT_EXPIRY=3600
SECURITY_REFRESH_TOKEN_ROTATION_ENABLED=true
SECURITY_REFRESH_TOKEN_REUSE_INTERVAL=10
SECURITY_MANUAL_LINKING_ENABLED=false
SECURITY_UPDATE_PASSWORD_REQUIRE_REAUTHENTICATION=false
SECURITY_CAPTCHA_ENABLED=false
SECURITY_CAPTCHA_PROVIDER=
SECURITY_CAPTCHA_SECRET=
SECURITY_CAPTCHA_CONFIG_SECRET_KEY=
SECURITY_CAPTCHA_CONFIG_SITE_KEY=

# ============================================
# 10. LOGS E ANALYTICS
# ============================================
LOGFLARE_API_KEY=
LOGFLARE_TOKEN=
LOGFLARE_ENABLED=false
LOG_LEVEL=info

# ============================================
# 11. DATABASE
# ============================================
DB_SSL=disable
DB_POOL_SIZE=10
DB_ENC_KEY=

# ============================================
# 12. MFA (Multi-Factor Auth)
# ============================================
MFA_CHALLENGE_EXPIRY_DURATION=
MFA_FACTORS_PHONE_OTP_LENGTH=6
MFA_FACTORS_PHONE_TEMPLATE=
MFA_FACTORS_TOTP_ENROLL_ENABLED=true
MFA_FACTORS_PHONE_ENROLL_ENABLED=true
MFA_FACTORS_TOTP_VERIFY_ENABLED=true
MFA_FACTORS_PHONE_VERIFY_ENABLED=true
MFA_MAX_ENROLLED_FACTORS=10
MFA_MAX_VERIFIED_FACTORS=10

# ============================================
# 13. REALTIME
# ============================================
MAX_CHANNELS_PER_CLIENT=100
MAX_JOIN_PAYLOAD_SIZE=
MAX_OUTBOUND_TIMEOUT=
SECRET_KEY_BASE=chave_secreta_para_realtime_gerar_nova

# ============================================
# 14. EDGE FUNCTIONS
# ============================================
FUNCTIONS_VERIFY_JWT=true

# ============================================
# 15. OUTROS
# ============================================
COOKIE_DOMAIN=
COOKIE_NAME=sb
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_EXTRA_SEARCH_PATH=extensions
