// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANCY - CICLO 1
// ============================================

/// Organization - Tenant principal do sistema
/// Cada organização pode ter múltiplos usuários com diferentes roles
model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique

  // Owner/Criador
  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id], name: "OwnedOrganizations")

  // Configurações
  logoUrl      String? @map("logo_url")
  featureFlags Json?   @map("feature_flags")
  settings     Json?

  // Status
  status OrganizationStatus @default(ACTIVE)

  // Relacionamentos
  members OrganizationMember[]
  units   OrganizationUnit[]

  // Integrações
  whatsappInstances  WhatsAppInstance[]
  instagramInstances InstagramInstance[]
  integrations       Integration[]

  // CRM
  pipelineStages PipelineStage[]
  deals          Deal[]
  contacts       Contact[]
  conversations  Conversation[]

  // Webhook Logs
  metaWebhookLogs MetaWebhookLog[]

  // Form Deliveries (Plano de Ação Integration)
  pendingFormDeliveries PendingFormDelivery[]

  // AI & Analytics
  aiInsights      AiInsight[]
  transcriptions  Transcription[]
  integrationLogs IntegrationActivityLog[]

  // Sprint 1: Contacts Core
  tags                   Tag[]
  lists                  List[]
  segments               Segment[]
  customFieldDefinitions CustomFieldDefinition[]

  // Sprint 2: Schedules
  schedules              Schedule[]

  // Sprint 5: Billing & Subscriptions
  subscriptions Subscription[]
  invoices      Invoice[]
  charges       Charge[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([status])
  @@index([slug])
  @@map("organizations")
}

/// OrganizationMember - Relacionamento many-to-many entre User e Organization
/// Um usuário pode ter roles diferentes em organizações diferentes
model OrganizationMember {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     OrganizationRole @default(MEMBER)
  status   MemberStatus     @default(ACTIVE)
  joinedAt DateTime         @default(now()) @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@map("organization_members")
}

/// OrganizationUnit - Unidades/Filiais de uma organização
model OrganizationUnit {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  slug      String
  isDefault Boolean @default(false) @map("is_default")
  settings  Json?

  // Relacionamentos
  deals Deal[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("organization_units")
}

/// User - Usuário do sistema
model User {
  id           String  @id @default(uuid())
  email        String  @unique
  name         String?
  avatarUrl    String? @map("avatar_url")
  passwordHash String? @map("password_hash")

  // Relacionamentos
  ownedOrganizations Organization[]       @relation(name: "OwnedOrganizations")
  memberships        OrganizationMember[]
  assignedDeals      Deal[]               @relation(name: "AssignedDeals")
  activities         DealActivity[]       @relation(name: "PerformedActivities")
  assignedSchedules  Schedule[]           @relation(name: "AssignedSchedules")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================
// WHATSAPP - CICLO 2 (Schema Flat)
// ============================================

/// WhatsAppInstance - Instância WhatsApp Business
/// Modelo adaptado para tabela whatsapp_cloud_instances do Aurea
model WhatsAppInstance {
  id String @id @default(uuid())

  // Relacionamentos principais
  agentId        String?      @map("agent_id")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unitId         String?      @map("unit_id")

  // Identificadores da Meta
  wabaId        String? @map("waba_id")
  phoneNumberId String? @map("phone_number_id")
  businessId    String? @map("business_id")

  // Informações do telefone
  displayPhoneNumber String? @map("display_phone_number")
  verifiedName       String? @map("verified_name")

  // Tokens (em produção, usar criptografia)
  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")

  // Status e Qualidade
  status          String  @default("DISCONNECTED") @map("status")
  webhookVerified Boolean @default(false) @map("webhook_verified")
  qualityRating   String? @map("quality_rating")
  messagingLimit  String? @map("messaging_limit")
  channelType     String? @map("channel_type")

  // Scopes e expiração
  scopes         String[]  @map("scopes")
  tokenExpiresAt DateTime? @map("token_expires_at")
  lastSyncAt     DateTime? @map("last_sync_at")

  // Erros e campos customizados
  errorMessage String? @map("error_message")
  customFields Json?   @map("custom_fields")

  // Campos mantidos para compatibilidade (não existem no Aurea, mas são usados no código)
  name               String
  phoneNumber        String    @map("phone_number")
  messagingTier      Int       @default(1) @map("messaging_tier")
  webhookVerifyToken String?   @map("webhook_verify_token")
  settings           Json?
  connectedAt        DateTime? @map("connected_at")

  // Relacionamentos
  templates             WhatsAppTemplate[]
  logs                  WhatsAppLog[]
  conversations         Conversation[]
  metaWebhookLogs       MetaWebhookLog[]
  pendingFormDeliveries PendingFormDelivery[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([status])
  @@index([phoneNumber])
  @@index([agentId])
  @@index([unitId])
  @@index([wabaId])
  @@index([phoneNumberId])
  @@map("whatsapp_cloud_instances")
}

/// WhatsAppTemplate - Templates de mensagem
/// Modelo adaptado para tabela whatsapp_cloud_templates do Aurea
model WhatsAppTemplate {
  id String @id @default(uuid())

  instanceId String           @map("instance_id")
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  templateId String? @unique @map("template_id")
  name       String
  category   String  @map("category")
  language   String  @map("language")

  // Componentes (JSON estruturado)
  components Json @map("components")

  // Conteúdo extraído
  body   String  @map("body")
  header String? @map("header")
  footer String? @map("footer")

  // Status
  status String  @default("DRAFT") @map("status")
  reason String? @map("reason")

  // Campos de timestamp do Aurea
  submittedAt DateTime? @map("submitted_at")
  approvedAt  DateTime? @map("approved_at")

  // Relacionamentos
  messages Message[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([instanceId])
  @@index([status])
  @@index([category])
  @@index([language])
  @@index([name, instanceId])
  @@map("whatsapp_cloud_templates")
}

/// WhatsAppLog - Logs de eventos e operações
/// Modelo adaptado para tabela whatsapp_cloud_logs do Aurea
model WhatsAppLog {
  id String @id @default(uuid())

  instanceId String           @map("instance_id")
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  // Campos mapeados para o Aurea
  eventType String  @map("event_type")
  payload   Json    @map("payload")
  level     String? @map("level")

  // Processamento
  processed   Boolean   @default(false) @map("processed")
  processedAt DateTime? @map("processed_at")
  error       String?   @map("error_message")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Campo type mantido para compatibilidade
  type String @default("") // message_received, message_sent, template_update, etc

  @@index([instanceId])
  @@index([type])
  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("whatsapp_cloud_logs")
}

// ============================================
// CONTACTS & MESSAGING - CICLO 2
// ============================================

/// Contact - Contatos unificados (WhatsApp, Instagram, etc)
model Contact {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  phone     String
  name      String?
  avatarUrl String? @map("avatar_url")

  // Dados customizados
  metadata  Json?
  tags      String[]
  leadScore Int      @default(0) @map("lead_score")

  // Status
  status ContactStatus @default(ACTIVE)

  // Tracking
  lastInteractionAt DateTime? @map("last_interaction_at")

  // Soft delete
  deletedAt DateTime? @map("deleted_at")

  // Relacionamentos
  conversations     Conversation[]
  messages          Message[]
  deals             Deal[]
  contactTags       ContactTag[]
  listContacts      ListContact[]
  customFieldValues ContactCustomFieldValue[]
  transcriptions    Transcription[]
  schedules         Schedule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([status])
  @@index([tags])
  @@index([leadScore])
  @@index([deletedAt])
  @@map("contacts")
}

/// Conversation - Conversas (janela de 24h)
model Conversation {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  instanceId String           @map("instance_id")
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  conversationId String?            @unique @map("conversation_id")
  type           ConversationType
  status         ConversationStatus @default(ACTIVE)

  // Janela de 24h
  windowStart DateTime @map("window_start")
  windowEnd   DateTime @map("window_end")

  // Tracking
  lastMessageAt DateTime? @map("last_message_at")
  messageCount  Int       @default(0) @map("message_count")

  // Relacionamentos
  messages       Message[]
  transcriptions Transcription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([instanceId])
  @@index([contactId])
  @@index([status])
  @@index([windowEnd])
  @@index([organizationId, contactId])
  @@map("conversations")
}

/// Message - Mensagens
model Message {
  id String @id @default(uuid())

  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  messageId String? @unique @map("message_id")

  // Direção e Tipo
  direction MessageDirection
  type      MessageType

  // Conteúdo
  content  String
  mediaUrl String? @map("media_url")
  caption  String?

  // Template (se aplicável)
  templateId String?           @map("template_id")
  template   WhatsAppTemplate? @relation(fields: [templateId], references: [id])

  // Status
  status MessageStatus @default(SENT)

  // Timestamps de status
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  readAt       DateTime? @map("read_at")
  failedAt     DateTime? @map("failed_at")
  failedReason String?   @map("failed_reason")

  // Dados adicionais
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([contactId])
  @@index([messageId])
  @@index([status])
  @@index([direction])
  @@index([type])
  @@index([createdAt])
  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================
// INSTAGRAM - CICLO 3
// ============================================

/// InstagramInstance - Instância Instagram Business
model InstagramInstance {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name String

  // IDs da Meta
  pageId                     String @map("page_id")
  instagramBusinessAccountId String @map("instagram_business_account_id")

  // Tokens
  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")

  // Perfil
  username          String?
  profilePictureUrl String? @map("profile_picture_url")

  // Status
  status InstagramInstanceStatus @default(DISCONNECTED)

  // Webhook
  webhookVerifyToken String? @map("webhook_verify_token")

  // Configurações
  settings Json?

  // Sync
  lastSyncAt DateTime? @map("last_sync_at")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  connectedAt DateTime? @map("connected_at")

  // Relacionamentos
  metaWebhookLogs MetaWebhookLog[]

  @@index([organizationId])
  @@index([status])
  @@index([instagramBusinessAccountId])
  @@map("instagram_instances")
}

// ============================================
// PIPELINE CRM - CICLO 3
// ============================================

/// PipelineStage - Etapas do funil de vendas
model PipelineStage {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  position    Int // Ordenação no pipeline
  color       String?
  probability Int     @default(0) // % de probabilidade de fechamento

  // Flags
  isDefault Boolean @default(false) @map("is_default")
  isClosed  Boolean @default(false) @map("is_closed") // Etapa de fechamento

  settings Json?

  // Relacionamentos
  deals Deal[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([position])
  @@map("pipeline_stages")
}

/// Deal - Oportunidades no pipeline
model Deal {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  stageId String        @map("stage_id")
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  unitId String?           @map("unit_id")
  unit   OrganizationUnit? @relation(fields: [unitId], references: [id])

  // Informações básicas
  title       String
  description String?

  // Valor
  amount   Decimal? @db.Decimal(15, 2)
  currency String   @default("BRL")

  // Lead Score e Probabilidade
  leadScore   Int  @default(0) @map("lead_score")
  probability Int? // Sobrescreve stage.probability se definido

  // Datas
  expectedCloseDate DateTime? @map("expected_close_date")
  actualCloseDate   DateTime? @map("actual_close_date")

  // Origem
  source   String? // whatsapp, instagram, manual, etc
  sourceId String? @map("source_id") // ID da conversa/origem

  // Responsável
  assignedTo String? @map("assigned_to")
  assignee   User?   @relation(fields: [assignedTo], references: [id], name: "AssignedDeals")

  // Status
  status   DealStatus   @default(OPEN)
  priority DealPriority @default(MEDIUM)

  // Dados customizados
  metadata Json?
  tags     String[]

  // Relacionamentos
  activities DealActivity[]
  schedules  Schedule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([stageId])
  @@index([assignedTo])
  @@index([status])
  @@index([priority])
  @@index([leadScore])
  @@index([source])
  @@index([tags])
  @@index([expectedCloseDate])
  @@map("deals")
}

/// DealActivity - Atividades e timeline do deal
model DealActivity {
  id String @id @default(uuid())

  dealId String @map("deal_id")
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  type     ActivityType
  title    String
  content  String?
  metadata Json?

  // Impacto no lead score
  scoreImpact Int @default(0) @map("score_impact")

  // Quem executou
  performedBy String? @map("performed_by")
  performer   User?   @relation(fields: [performedBy], references: [id], name: "PerformedActivities")

  // Automação (se triggered por automação)
  automationId String? @map("automation_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId])
  @@index([type])
  @@index([performedBy])
  @@index([createdAt])
  @@map("deal_activities")
}

// ============================================
// META WEBHOOK LOGS - CICLO 4
// ============================================

/// MetaWebhookLog - Logs de webhooks da Meta (WhatsApp/Instagram)
/// Tabela unificada para rastrear todos os eventos de webhook
model MetaWebhookLog {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  whatsappInstanceId String?           @map("whatsapp_instance_id")
  whatsappInstance   WhatsAppInstance? @relation(fields: [whatsappInstanceId], references: [id], onDelete: SetNull)

  instagramInstanceId String?            @map("instagram_instance_id")
  instagramInstance   InstagramInstance? @relation(fields: [instagramInstanceId], references: [id], onDelete: SetNull)

  eventType String @map("event_type")
  payload   Json?

  // Processamento
  forwardedToN8n Boolean   @default(false) @map("forwarded_to_n8n")
  processed      Boolean   @default(false)
  processedAt    DateTime? @map("processed_at")
  errorMessage   String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([whatsappInstanceId])
  @@index([instagramInstanceId])
  @@index([eventType])
  @@index([createdAt])
  @@index([processed])
  @@map("meta_webhook_logs")
}

// ============================================
// SPRINT 2: SCHEDULES - AGENDAMENTOS
// ============================================

enum ScheduleType {
  meeting
  task
  call
  deadline
}

enum ScheduleStatus {
  pending
  completed
  cancelled
}

model Schedule {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type ScheduleType

  title       String
  description String?

  // Relacionamentos opcionais
  contactId String?  @map("contact_id")
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId String? @map("deal_id")
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  assignedTo String? @map("assigned_to")
  assignee   User?   @relation(fields: [assignedTo], references: [id], onDelete: SetNull, name: "AssignedSchedules")

  // Datas
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")

  completedAt DateTime? @map("completed_at")
  status      ScheduleStatus @default(pending)

  // Local/link para reuniões
  location String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([dealId])
  @@index([assignedTo])
  @@index([status])
  @@index([startTime])
  @@index([organizationId, startTime])
  @@map("schedules")
}

// ============================================
// SPRINT 1: CONTACTS CORE - TAGS, LISTS, SEGMENTS, CUSTOM FIELDS
// ============================================

/// Tag - Tags para categorização de contatos
model Tag {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  color       String  @default("#6366f1")
  description String?
  source      String  @default("manual") // manual, automation, utm

  // Relacionamentos
  contactTags ContactTag[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([name])
  @@map("tags")
}

/// ContactTag - Relacionamento many-to-many entre Contact e Tag
model ContactTag {
  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  @@id([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
  @@map("contact_tags")
}

/// List - Listas de contatos (estáticas ou dinâmicas)
model List {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  filters      Json    @default("{}")
  isDynamic    Boolean @default(false) @map("is_dynamic")
  contactCount Int     @default(0) @map("contact_count")

  createdBy String? @map("created_by")

  // Relacionamentos
  listContacts ListContact[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("lists")
}

/// ListContact - Relacionamento many-to-many entre List e Contact
model ListContact {
  listId String @map("list_id")
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now()) @map("added_at")
  addedBy String?  @map("added_by")

  @@id([listId, contactId])
  @@index([listId])
  @@index([contactId])
  @@map("list_contacts")
}

/// CustomFieldDefinition - Definições de campos customizados
model CustomFieldDefinition {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  key          String
  description  String?
  type         String // text, number, date, select, boolean, etc
  required     Boolean @default(false)
  options      Json    @default("[]")
  displayOrder Int     @default(0) @map("display_order")
  isActive     Boolean @default(true) @map("is_active")

  // Relacionamentos
  values ContactCustomFieldValue[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([isActive])
  @@map("custom_field_definitions")
}

/// ContactCustomFieldValue - Valores de campos customizados para contatos
model ContactCustomFieldValue {
  id String @id @default(uuid())

  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  fieldId String                @map("field_id")
  field   CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  value String?

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([contactId, fieldId])
  @@index([contactId])
  @@index([fieldId])
  @@map("contact_custom_field_values")
}

/// Segment - Segmentos dinâmicos de contatos
model Segment {
  id String @id @default(uuid())

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name             String
  description      String?
  rules            Json      @default("[]")
  contactCount     Int       @default(0) @map("contact_count")
  lastCalculatedAt DateTime? @map("last_calculated_at")

  createdBy String? @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("segments")
}

